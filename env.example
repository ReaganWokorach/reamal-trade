# =============================================================
# REAMAL Trade — Environment Variables Template
# =============================================================
# INSTRUCTIONS:
# 1. Make a copy of this file and name it exactly:  .env
# 2. Fill in your actual values below
# 3. NEVER push your .env file to GitHub — it contains secrets!
#    (The .gitignore file will protect it automatically)
# =============================================================


# -------------------------------------------------------------
# ANTHROPIC API KEY (Required)
# -------------------------------------------------------------
# This powers the AI chart analysis engine (Claude AI)
#
# How to get your free key:
#   1. Go to https://console.anthropic.com
#   2. Sign up for a free account
#   3. Click "API Keys" in the left menu
#   4. Click "Create Key" and copy it here
#
# Free tier includes enough credits to get started.
# -------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# -------------------------------------------------------------
# APP SETTINGS (Optional — defaults are already set in code)
# -------------------------------------------------------------

# The AI model to use — leave this as is
CLAUDE_MODEL=claude-sonnet-4-20250514

# Maximum tokens for AI response (higher = more detailed analysis)
MAX_TOKENS=1500

# Your default trading account balance in USD (used by Risk Manager)
DEFAULT_ACCOUNT_BALANCE=100

# Maximum risk percentage per trade (recommended: 1 or 2)
MAX_RISK_PERCENT=2


# =============================================================
# AFTER FILLING IN YOUR VALUES:
#
#   Local development:
#     - Save this file as .env in the root folder
#     - Run: netlify dev
#
#   Netlify deployment:
#     - Go to: Site Settings → Environment Variables
#     - Add ANTHROPIC_API_KEY and its value there
#     - You do NOT upload the .env file to Netlify directly
# =============================================================
